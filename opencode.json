{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    ".github/copilot-instructions.md",
    "AGENTS.md"
  ],
  "permission": {
    "skill": {
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
      }
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".vs/**",
      ".vscode/**",
      "**/bin/**",
      "**/obj/**",
      "**/node_modules/**",
      "**/dist/**",
      "**/.angular/**",
      "**/coverage/**",
      "**/playwright-report/**",
      "**/test-results/**",
      "**/*.log",
      "docker-compose/logs/**"
    ]
  }
}
